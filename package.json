{
  "name": "kairous",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:small": "vitest run --project small",
    "test:medium": "vitest run --project medium",
    "test:large": "playwright test --config tests/large/playwright.config.ts",
    "test:watch": "vitest",
    "check": "bun run lint && bun run typecheck && bun test:small",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.515.0",
    "next": "16.2.2",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.1",
    "shadcn": "4.1.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "ts-fsrs": "5.3.2",
    "tw-animate-css": "1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "supabase": "^2.84.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "lefthook",
    "sharp",
    "supabase",
    "unrs-resolver"
  ]
