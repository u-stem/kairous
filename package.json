{
  "name": "kairous",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:small": "vitest run --project small",
    "test:medium": "vitest run --project medium",
    "test:large": "playwright test --config tests/large/playwright.config.ts",
    "test:watch": "vitest",
    "lhci:setup": "playwright test --config tests/large/playwright.config.ts --project=setup",
    "lhci": "lhci autorun",
    "check": "bun run lint && bun run typecheck && bun test:small",
    "check:lighthouse-coverage": "bun run scripts/check-lighthouse-coverage.ts",
    "worktree:create": "bun run scripts/worktree.ts create",
    "worktree:cleanup": "bun run scripts/worktree.ts cleanup",
    "worktree:list": "bun run scripts/worktree.ts list",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@base-ui/react": "1.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.1",
    "shadcn": "4.1.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "ts-fsrs": "5.3.2",
    "tw-animate-css": "1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "puppeteer": "24.40.0",
    "supabase": "^2.92.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wait-on": "9.0.5"
  },
  "overrides": {
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "basic-ftp": "^5.3.0",
    "tmp": "^0.2.5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "lefthook",
    "sharp",
    "supabase",
    "unrs-resolver"
  ]
}
